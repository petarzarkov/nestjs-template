{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "jsPlugins": [
    {
      "name": "typeorm",
      "specifier": "./oxlint-plugins/eslint-plugin-typeorm.mjs"
    }
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-explicit-any": "error",
    "typescript/no-inferrable-types": "off",
    "no-unused-vars": [
      "error",
      {
        "ignoreRestSiblings": true,
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrors": "none"
      }
    ],
    "max-lines": ["error", { "max": 500, "skipBlankLines": true }],
    "typeorm/explicit-naming": "error",
    "typeorm/timestamptz": "error",
    "typeorm/column-length": "error"
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/migrations/**",
    "**/*.d.ts",
    "**/*.spec.ts",
    "**/*.e2e.spec.ts",
    "coverage/**",
    "node_modules/**",
    ".tmp/**",
    "public/**"
  ]
}
