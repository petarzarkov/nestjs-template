{
  "name": "nestjs-template",
  "version": "0.1.0",
  "private": true,
  "description": "A production-ready NestJS monolith template with TypeScript, TypeORM, and modern tooling.",
  "license": "MIT",
  "author": {
    "name": "Petar Zarkov",
    "email": "pzarko1@gmail.com",
    "url": "https://github.com/petarzarkov/"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "dev": "bun --watch src/main.ts",
    "dev:nest": "nest start --watch --exec bun",
    "start": "bun dist/main.js",
    "build": "bun ./scripts/build.ts",
    "gen:env:docs": "bun ./scripts/gen-env-docs.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage",
    "test:e2e": "bun test --env-file=./e2e/.env --preload ./e2e/setup/preload.ts ./e2e/**/*.e2e.spec.ts",
    "test:e2e:single": "bun test --timeout 30000 --env-file=./e2e/.env --preload ./e2e/setup/preload.ts --bail",
    "email": "email dev --dir src/notifications/email/templates --port 3035",
    "email:export": "email export --dir src/notifications/email/templates",
    "lint": "oxlint --fix src e2e scripts",
    "format": "oxfmt .",
    "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json",
    "typeorm": "bun --env-file=.env ./node_modules/typeorm/cli.js -d src/infra/db/data-source-options.ts",
    "mig:gen": "bash ./scripts/migration-generate.sh",
    "mig:run": "bun run typeorm migration:run",
    "mig:run:prod": "NODE_ENV=production bun ./node_modules/typeorm/cli.js -d dist/infra/db/data-source-options.js migration:run",
    "mig:revert": "bun run typeorm migration:revert",
    "db:drop": "bun run typeorm schema:drop",
    "create:admin": "bun --env-file=.env ./scripts/create-admin.ts",
    "mod:cost": "bunx @pzarkov/module-cost --less"
  },
  "dependencies": {
    "@ai-sdk/google": "4.0.1",
    "@ai-sdk/openai": "4.0.1",
    "@aws-sdk/client-s3": "3.1075.0",
    "@bull-board/api": "8.0.1",
    "@bull-board/express": "8.0.1",
    "@bull-board/nestjs": "8.0.1",
    "@nest-lab/throttler-storage-redis": "1.2.0",
    "@nestjs/axios": "4.0.1",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/cache-manager": "3.1.3",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/microservices": "11.1.27",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/platform-socket.io": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/serve-static": "5.0.5",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.3",
    "@nestjs/websockets": "11.1.27",
    "@react-email/components": "1.0.12",
    "@scalar/nestjs-api-reference": "1.2.6",
    "@socket.io/redis-adapter": "8.3.0",
    "@socket.io/redis-emitter": "5.1.0",
    "axios": "1.18.1",
    "bullmq": "5.79.1",
    "cache-manager": "7.2.8",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "decimal.js": "10.6.0",
    "image-size": "2.0.2",
    "ioredis": "5.11.1",
    "mime-types": "3.0.2",
    "passport-github2": "0.1.12",
    "passport-google-oauth20": "2.0.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "passport-oauth2": "1.8.0",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "reflect-metadata": "0.2.2",
    "resend": "6.16.0",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "stripe": "^22.3.0",
    "typeorm": "1.0.0",
    "uuid": "14.0.1",
    "vercel-ai": "npm:ai@7.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/testing": "11.1.27",
    "@react-email/preview-server": "5.2.10",
    "@types/bun": "1.3.14",
    "@types/express": "5.0.6",
    "@types/mime-types": "3.0.1",
    "@types/multer": "2.1.0",
    "@types/passport-github2": "1.2.9",
    "@types/passport-google-oauth20": "2.0.17",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@typescript/native-preview": "7.0.0-dev.20260627.2",
    "glob": "13.0.6",
    "husky": "9.1.7",
    "inquirer": "14.0.2",
    "lint-staged": "17.0.8",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "socket.io-client": "4.8.3",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.json": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
